name: Deploy to Aston

on:
  push:
    branches:
      - main

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Start SSH agent
        uses: webfactory/ssh-agent@v0.9.0
        with:
          ssh-private-key: ${{ secrets.ASTON_SSH_KEY }}

      - name: Deploy
        run: |
          ssh -o StrictHostKeyChecking=no ${{ secrets.ASTON_USER }}@${{ secrets.ASTON_HOST }} << 'EOF'
            cd /home/cs2team17/drip-and-co
            git pull origin main
            php a
